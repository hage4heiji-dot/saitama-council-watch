# このファイルをコピーして .env を作成し、実際の値を入れること。
# .env はgit管理外(.gitignore参照)。

NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:3000

# --- PostgreSQL(永続業務データ + 公開AIコンテンツ。docs/adr/0006) ---
POSTGRES_USER=app
POSTGRES_PASSWORD=change-me
POSTGRES_DB=saitama_council_watch
DATABASE_URL=postgresql://app:change-me@postgres:5432/saitama_council_watch

# --- SQLite(AI専用の技術的キャッシュ。docs/adr/0006) ---
SQLITE_PATH=/data/sqlite/ai-cache.db

# --- Claude API(docs/design/00-constitution.md AIの役割) ---
CLAUDE_API_KEY=

# --- OAuth(Phase4。docs/adr/0004) ---
AUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- 通知チャネル(Phase4。docs/adr/0004、複数チャネル対応) ---
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
LINE_NOTIFY_CHANNEL_ACCESS_TOKEN=
