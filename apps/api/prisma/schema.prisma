// さいたま市議会ウォッチ - PostgreSQLスキーマ
// 設計根拠: docs/design/01-basic-design.md §3.1, docs/adr/0006-ai-content-storage-split.md
//
// 原則:
//   - documents は追記専用(immutable)。原本更新時は version をインクリメントして新規行を追加する。
//   - ai_contents.sourceDocumentId は必須(NOT NULL)。原本のないAI生成コンテンツを
//     DB制約レベルで禁止する(「AIは事実を創作してはいけない」docs/design/00-constitution.md)。
//   - SQLite側(embedding/FTS/LLM応答キャッシュ)はこのPrismaスキーマの対象外。
//     apps/api/src/infrastructure/db/sqlite を参照。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MeetingType {
  PLENARY // 本会議
  COMMITTEE // 委員会
}

enum MeetingStatus {
  SCHEDULED
  HELD
  CANCELLED
}

enum BillStatus {
  SUBMITTED
  IN_DELIBERATION
  PASSED
  REJECTED
  CARRIED_OVER // 継続審議
  // 会期終了後、審議結果の原本(委員会審査結果報告等)を確認しても結果を特定できなかった議案。
  // 「提出」のまま放置すると未審議であるかのように見えてしまうため、明示的に区別する
  // (docs/adr/0016-bill-deliberation-status-sync.md、捏造しないという方針より)。
  UNCONFIRMED
}

enum OrdinanceStatus {
  IN_FORCE
  ABOLISHED
}

enum PetitionStatus {
  // 請願文書表(全文)はあるが、まだ請願審議結果一覧に載っていない(審議中)
  PENDING
  ADOPTED // 採択
  REJECTED // 不採択
  WITHDRAWN // 取下げ
  CARRIED_OVER // 継続審査
  // 審議結果一覧に載っているが、既知の結果文言(採択/不採択/取下げ/継続審査)と一致しない
  // (捏造を避けるため、docs/adr/0026)
  UNCONFIRMED
}

enum VoteType {
  FOR
  AGAINST
  ABSENT
  ABSTAIN
}

enum DocumentType {
  PDF
  HTML
  MARKDOWN
  JSON
}

enum AiContentType {
  SUMMARY
  TAGS
  FAQ
  RELATED_INFO
}

enum NotificationChannel {
  EMAIL
  LINE
  PUSH
}

enum BatchJobStatus {
  RUNNING
  SUCCEEDED
  FAILED
}

model Faction {
  id          String    @id @default(uuid())
  name        String
  foundedDate DateTime? @map("founded_date") @db.Date
  isActive    Boolean   @default(true) @map("is_active")

  legislatorHistory LegislatorFactionHistory[]

  @@unique([name])
  @@map("factions")
}

model Legislator {
  id               String    @id @default(uuid())
  name             String
  nameKana         String    @map("name_kana")
  firstElectedDate DateTime? @map("first_elected_date") @db.Date
  isActive         Boolean   @default(true) @map("is_active")
  profileUrl       String?   @map("profile_url")

  factionHistory      LegislatorFactionHistory[]
  votes               Vote[]
  petitionIntroducers PetitionIntroducer[]

  // スクレイピング時の自然キー(プロフィールページURL)。手動追加データはnull許容のまま。
  @@unique([profileUrl])
  @@map("legislators")
}

// 会派移動の履歴。現在の会派は valid_to が null の行。
model LegislatorFactionHistory {
  id           String    @id @default(uuid())
  legislatorId String    @map("legislator_id")
  factionId    String    @map("faction_id")
  validFrom    DateTime  @map("valid_from") @db.Date
  validTo      DateTime? @map("valid_to") @db.Date

  legislator Legislator @relation(fields: [legislatorId], references: [id])
  faction    Faction    @relation(fields: [factionId], references: [id])

  @@index([legislatorId])
  @@map("legislator_faction_history")
}

model Meeting {
  id          String        @id @default(uuid())
  name        String
  meetingType MeetingType   @map("meeting_type")
  sessionName String        @map("session_name")
  // 会期予定表(「日程（6月3日～6月26日 24日間）」)から取得する会期の開始日・終了日。
  // Phase1b(docs/adr/0011)で会議日程スクレイピングにより補完するまではnullable。
  // 個別の本会議・委員会単位のより粒度の細かい日程は将来の別モデル化を検討する。
  startDate   DateTime?     @map("start_date") @db.Date
  endDate     DateTime?     @map("end_date") @db.Date
  status      MeetingStatus @default(SCHEDULED)

  bills             Bill[]
  committeeMeetings CommitteeMeeting[]
  petitions         Petition[]

  @@unique([sessionName, meetingType])
  @@map("meetings")
}

// 会議日程一覧(docs/adr/0023)から取得する、本会議・委員会単位の個別日程。
// Meetingが会期(定例会・臨時会)全体の期間を表すのに対し、こちらは1日単位の実際の開催記録。
// committeeNameは原本の表記をそのまま保持する(「予算委員会（企業会計関係審査）【中継】」等、
// 捏造せず正規化しすぎない方針)。meetingIdはdateが対応するMeetingの会期内に収まる場合のみ設定し、
// 判定できない場合はnullのままにする。
model CommitteeMeeting {
  id            String   @id @default(uuid())
  date          DateTime @db.Date
  // 原本の時刻表記をそのまま保持する(「10時」「9時30分」「散会後」等)。無い場合はnull。
  time          String?
  committeeName String   @map("committee_name")
  meetingId     String?  @map("meeting_id")

  meeting Meeting? @relation(fields: [meetingId], references: [id])

  @@unique([date, committeeName])
  @@index([meetingId])
  @@map("committee_meetings")
}

model Bill {
  id               String     @id @default(uuid())
  meetingId        String     @map("meeting_id")
  billNumber       String     @map("bill_number")
  title            String
  category         String
  // 原本ページの見出しから解析できた場合のみ設定する。解析できない書式のページも
  // あるため、値を捏造しないようnullableにする(docs/design/00-constitution.md)。
  submittedDate    DateTime?  @map("submitted_date") @db.Date
  status           BillStatus @default(SUBMITTED)
  sourceDocumentId String     @map("source_document_id")

  meeting        Meeting     @relation(fields: [meetingId], references: [id])
  sourceDocument Document    @relation(fields: [sourceDocumentId], references: [id])
  votes          Vote[]
  ordinances     Ordinance[]
  budgets        Budget[]

  @@unique([meetingId, billNumber])
  @@index([sourceDocumentId])
  @@map("bills")
}

model Ordinance {
  id               String          @id @default(uuid())
  title            String
  enactedDate      DateTime        @map("enacted_date") @db.Date
  billId           String?         @map("bill_id")
  status           OrdinanceStatus @default(IN_FORCE)
  sourceDocumentId String          @map("source_document_id")

  bill           Bill?    @relation(fields: [billId], references: [id])
  sourceDocument Document @relation(fields: [sourceDocumentId], references: [id])

  @@index([sourceDocumentId])
  @@map("ordinances")
}

// 請願(docs/adr/0026)。原文(要旨)まで保持する。紹介議員は複数人つきうるため
// PetitionIntroducerで多対多にする(実データで複数人の例を確認済み)。
model Petition {
  id               String         @id @default(uuid())
  meetingId        String         @map("meeting_id")
  // 会計年度内でリセットされることがある(実データで確認済み)ため、
  // (meetingId, petitionNumber)で一意にする
  petitionNumber   String         @map("petition_number")
  title            String
  receivedDate     DateTime?      @map("received_date") @db.Date
  // 住所は原本でも伏字のため保持しない。氏名・団体名のみ
  petitionerName   String         @map("petitioner_name")
  committeeName    String?        @map("committee_name")
  summary          String
  status           PetitionStatus @default(PENDING)
  decidedDate      DateTime?      @map("decided_date") @db.Date
  sourceDocumentId String         @map("source_document_id")

  meeting        Meeting              @relation(fields: [meetingId], references: [id])
  sourceDocument Document             @relation(fields: [sourceDocumentId], references: [id])
  introducers    PetitionIntroducer[]

  @@unique([meetingId, petitionNumber])
  @@index([sourceDocumentId])
  @@map("petitions")
}

model PetitionIntroducer {
  id           String  @id @default(uuid())
  petitionId   String  @map("petition_id")
  legislatorId String? @map("legislator_id")
  // 原本の表記(捏造しない)。既存Legislatorと一致しない場合はlegislatorIdがnullのまま残る
  rawName      String  @map("raw_name")

  petition   Petition    @relation(fields: [petitionId], references: [id], onDelete: Cascade)
  legislator Legislator? @relation(fields: [legislatorId], references: [id])

  @@unique([petitionId, rawName])
  @@map("petition_introducers")
}

model Vote {
  id           String   @id @default(uuid())
  billId       String   @map("bill_id")
  legislatorId String   @map("legislator_id")
  voteType     VoteType @map("vote_type")
  votedAt      DateTime @map("voted_at")

  bill       Bill       @relation(fields: [billId], references: [id])
  legislator Legislator @relation(fields: [legislatorId], references: [id])

  @@unique([billId, legislatorId])
  @@map("votes")
}

model Budget {
  id            String  @id @default(uuid())
  fiscalYear    Int     @map("fiscal_year")
  // 一般会計/各特別会計の別。同じ款名(例:「総務費」)が会計をまたいで重複しうるため、
  // (fiscalYear, accountName, category) で一意にする(docs/adr/0024)。
  accountName   String  @map("account_name")
  category      String
  // 款番号(原本の表記通り。表示順の並べ替えに使う。docs/adr/0024)
  categoryOrder Int     @map("category_order")
  amount        Decimal @db.Decimal(14, 0)
  relatedBillId String? @map("related_bill_id")
  description   String

  relatedBill Bill? @relation(fields: [relatedBillId], references: [id])

  @@unique([fiscalYear, accountName, category])
  @@map("budgets")
}

// 原本管理: 追記専用。改変・削除しない。
model Document {
  id          String       @id @default(uuid())
  type        DocumentType
  sourceUrl   String       @map("source_url")
  storagePath String       @map("storage_path")
  checksum    String // sha256 hex
  version     Int          @default(1)
  fetchedAt   DateTime     @map("fetched_at")

  bills      Bill[]
  ordinances Ordinance[]
  aiContents AiContent[]
  petitions  Petition[]

  @@unique([sourceUrl, version])
  @@index([checksum])
  @@map("documents")
}

// 公開用AI生成コンテンツ。docs/adr/0006, 0007 参照。
model AiContent {
  id               String        @id @default(uuid())
  sourceDocumentId String        @map("source_document_id")
  contentType      AiContentType @map("content_type")
  body             String
  modelVersion     String        @map("model_version")
  promptVersion    String        @map("prompt_version")
  generatedAt      DateTime      @map("generated_at")
  isVerified       Boolean       @default(false) @map("is_verified")
  verifiedBy       String?       @map("verified_by")
  verifiedAt       DateTime?     @map("verified_at")
  // グラウンディング検証(機械的チェック・自己検証パス)で問題が見つかった場合のみ設定。
  // 管理確認画面(docs/adr/0007)でレビュー担当者が理由を確認できるようにする。
  groundingNote    String?       @map("grounding_note")

  sourceDocument Document @relation(fields: [sourceDocumentId], references: [id])

  @@index([sourceDocumentId])
  @@index([isVerified])
  @@map("ai_contents")
}

model User {
  id             String   @id @default(uuid())
  oauthProvider  String   @map("oauth_provider")
  oauthSubjectId String   @map("oauth_subject_id")
  email          String   @unique
  displayName    String   @map("display_name")
  createdAt      DateTime @default(now()) @map("created_at")

  notificationSettings NotificationSetting[]

  @@unique([oauthProvider, oauthSubjectId])
  @@map("users")
}

model NotificationSetting {
  id          String              @id @default(uuid())
  userId      String              @map("user_id")
  channel     NotificationChannel
  topicFilter Json                @map("topic_filter")
  isEnabled   Boolean             @default(true) @map("is_enabled")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, channel])
  @@map("notification_settings")
}

// バッチジョブ実行履歴。ソロ運用における唯一の観測手段(docs/design/01-basic-design.md §7)。
model BatchJobRun {
  id               String         @id @default(uuid())
  jobName          String         @map("job_name")
  startedAt        DateTime       @map("started_at")
  finishedAt       DateTime?      @map("finished_at")
  status           BatchJobStatus @default(RUNNING)
  errorMessage     String?        @map("error_message")
  recordsProcessed Int            @default(0) @map("records_processed")

  @@index([jobName, startedAt])
  @@map("batch_job_runs")
}
